Proceso preparando_sandwich
	Escribir "********PREPARANDO MI SANDWICH******";
	Escribir "1. Tomar dos rebanadas de pan";
	Escribir "2. Untar mantequilla en una de las rebanadas";
	Escribir "3. Colocar jamón encima";
	Escribir "4. Agregar queso";
	Escribir "5. Cerrar el sándwich con la otra rebanada";
	Escribir "6. Cortar si es necesario";
	Escribir "7. Servir!";
FinProceso
